# Copy this file to .env and fill in values for production.
# Never commit .env to version control.

SPRING_PROFILES_ACTIVE=prod

# JWT - generate with: openssl rand -base64 64
JWT_SECRET=replace-with-a-strong-base64-encoded-secret-at-least-256-bits
JWT_EXPIRATION_MS=86400000

# Business rules
LOAN_DURATION_DAYS=14
FINE_PER_DAY=0.50

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=librarydb
DB_USERNAME=libraryuser
DB_PASSWORD=replace-with-strong-password
